export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="{{ zsh_theme }}"
plugins=({{ zsh_plugins | join(' ') }})

# --- Shell history settings ---
HISTSIZE=10000        # Number of commands kept in memory
SAVEHIST=10000        # Number of commands saved to ~/.zsh_history
HISTFILE="$HOME/.zsh_history"

setopt HIST_IGNORE_DUPS      # Ignore duplicate entries
setopt HIST_IGNORE_SPACE     # Ignore commands starting with space
setopt HIST_VERIFY           # Show before executing recalled command
setopt SHARE_HISTORY         # Share command history between sessions
# -------------------------------

source $ZSH/oh-my-zsh.sh

# Add your custom aliases or exports below
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
